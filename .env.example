# ===========================================
# Mercado Pago — Produção (Kryska)
# ===========================================
# 1. Copie este arquivo para .env e preencha com suas credenciais de PRODUÇÃO.
# 2. No Vercel: Project > Settings > Environment Variables (Production).
# 3. Nunca commite .env. Certifique-se de que .env está no .gitignore.
# ===========================================

# --- Backend (API serverless) ---
# Access Token de PRODUÇÃO (Painel MP: Sua integração > Credenciais > Produção)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL pública do site (usada nas back_urls do checkout)
PUBLIC_URL=https://www.kryska.com.br

# --- Frontend (build Vite) ---
# Chave pública de PRODUÇÃO (Credenciais > Produção > Chave pública)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Deixe em branco ou false para produção. Use true apenas para testes com usuários de teste MP.
VITE_MP_SANDBOX=false
